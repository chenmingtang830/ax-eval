# ax-eval — env stub. Copy to .env, fill in, never commit the real one.
#
# Each pack declares the env it needs (auth + sandbox_scope + per-surface auth).
# The shipped packs under targets/ are illustrative examples — uncomment the
# block for the one(s) you're running, or
# print a stub for any pack (including your own) with:
#
#     ax-eval init --pack <pack.yaml>                    # api + sandbox stub
#     ax-eval init --pack <pack.yaml> --surface all      # + every surface's auth
#     ax-eval check-env --pack <pack.yaml> --surface all # verifies what's set
#
# Surfaces authenticate independently. The api/cli/sdk surfaces reuse the API
# token below (kind: inherit). MCP differs by vendor: Monday/Linear take the
# same token; Asana/Notion are OAuth-only, so their MCP surface stays BLOCKED
# (requires-oauth) until you register an OAuth app and store a refresh token.
# Missing a surface's credential only blocks THAT surface — the api surface (and
# any token surface) still runs, and the blocked surface shows as a "blocked"
# cube cell rather than a misleading 0%.
#
# Keyless paths need NONE of these:
#   ax-eval run --offline   ·   ax-eval audit --site <url>   ·   npm test

# --- Asana (REST) --- example: targets/asana/pack.yaml
# ASANA_PAT=                       # api + sdk (sdk inherits this PAT)
# ASANA_VERIFY_PAT=                # optional; falls back to ASANA_PAT
# ASANA_SANDBOX_PROJECT_GID=
# ASANA_SANDBOX_WORKSPACE_GID=     # optional; unlocks workspace-scoped tasks
# Asana MCP surface (OAuth-only — register an app at app.asana.com/0/my-apps):
# ASANA_MCP_CLIENT_ID=
# ASANA_MCP_CLIENT_SECRET=
# ASANA_MCP_REFRESH_TOKEN=

# --- Notion (REST) --- example: targets/notion/pack.yaml
# NOTION_TOKEN=                    # api + sdk (sdk inherits this token)
# NOTION_VERIFY_TOKEN=             # optional; falls back to NOTION_TOKEN
# NOTION_SANDBOX_PARENT_PAGE_ID=
# NOTION_SANDBOX_DATA_SOURCE_ID=   # optional
# Notion MCP surface (hosted MCP is OAuth-only — create a public integration):
# NOTION_MCP_CLIENT_ID=
# NOTION_MCP_CLIENT_SECRET=
# NOTION_MCP_REFRESH_TOKEN=

# --- Linear (GraphQL) --- example: targets/linear/pack.yaml
# LINEAR_API_KEY=                  # api + sdk + mcp (Linear MCP takes this key)
# LINEAR_SANDBOX_TEAM_ID=

# --- Monday.com (GraphQL) --- example: targets/monday/pack.yaml
# MONDAY_API_KEY=                  # api + sdk + mcp (local MCP takes this key)
# MONDAY_SANDBOX_BOARD_ID=
