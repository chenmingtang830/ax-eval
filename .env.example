# AX eval — environment template.
# Copy to `.env` and fill in real values. `.env` is git-ignored; never commit real keys.
#
# Two layers of keys (see skill-spec.md §4):
#   1. GLOBAL model/harness keys — stable, shared across all targets (below).
#   2. PER-TARGET keys — each target pack DECLARES its own var names in its
#      agent_env / verify_env. Adding a new SaaS = add its vars here + name them
#      in the pack. No code change, no generic secrets system needed.
#   Asana is the first reference target pack; its vars are shown below.

# --- Target keys: asana (declared by targets/asana/pack.yaml) ---
# Agent's key (BYOK): the key handed to the agent under test.
ASANA_PAT=

# Oracle's verification key — OPTIONAL. The idea is a separate, narrower (read-only)
# token for verifying state. But Asana PATs can't be scoped (they inherit the full
# user's permissions), so a second same-account token buys no real isolation. Leave
# blank for v0; the runner falls back to ASANA_PAT. (Matters for targets with
# scopable keys, e.g. Stripe restricted keys or GitHub fine-grained PATs.)
ASANA_VERIFY_PAT=

# The sandbox project the agent creates/mutates tasks in, and that reset.ts cleans.
ASANA_SANDBOX_PROJECT_GID=

# --- Harness model keys ---
# Claude Code (claude -p ... headless)
ANTHROPIC_API_KEY=

# Codex (codex exec ...) and the minimal harness baseline
OPENAI_API_KEY=
