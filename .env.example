# ax-eval — environment template
#
# Copy this file to `.env`, fill in only the targets you plan to run, and never
# commit the real `.env`.
#
# Print the exact env stub for any pack with:
#
#   ax-eval init --pack <pack.yaml>
#   ax-eval init --pack <pack.yaml> --surface all
#   ax-eval check-env --pack <pack.yaml> --surface all
#
# Keyless paths need none of these:
#   npm test
#   npm run ax-eval -- run --offline
#   npm run ax-eval -- audit --site <url>

# Optional harness credentials for hosted/headless runs.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional authoring/generation defaults used by resolve-vendor, extract-surfaces,
# extract-capabilities, extract-tasks, synthesize-suite, and generate.
# CLI flags still take precedence:
#   --generator-harness codex|claude-code
#   --generator-model <model>
#   --generator-effort low|medium|high
AX_EVAL_GENERATOR_HARNESS=claude-code
AX_EVAL_GENERATOR_EFFORT=medium
# If AX_EVAL_GENERATOR_MODEL is set, it overrides the harness-specific defaults.
AX_EVAL_GENERATOR_MODEL=
AX_EVAL_GENERATOR_CLAUDE_MODEL=claude-sonnet-5
AX_EVAL_GENERATOR_CODEX_MODEL=gpt-5.4

# -----------------------------------------------------------------------------
# DAEB-1 / Nile
# Auth: API key for headless CLI/control-plane operations
# Sandbox: one free-tier workspace + disposable database
# -----------------------------------------------------------------------------
NILE_API_KEY=
NILE_WORKSPACE=
NILE_DATABASE=
NILE_DATABASE_URL=

# -----------------------------------------------------------------------------
# Exa
# Auth: API key
# Sandbox granularity: none
# Targets: targets/exa/pack.yaml
# -----------------------------------------------------------------------------
EXA_API_KEY=

# -----------------------------------------------------------------------------
# Linear
# Auth: personal API key
# Sandbox granularity: one throwaway team
# Targets: targets/linear/pack.yaml
# -----------------------------------------------------------------------------
LINEAR_API_KEY=
LINEAR_SANDBOX_TEAM_ID=

# -----------------------------------------------------------------------------
# Notion
# Auth: integration token
# Sandbox granularity: one sandbox parent page
# Targets: targets/notion/pack.yaml
# -----------------------------------------------------------------------------
NOTION_TOKEN=
NOTION_VERIFY_TOKEN=
NOTION_SANDBOX_PARENT_PAGE_ID=

# Optional surface helpers.
NOTION_API_TOKEN=
NOTION_API_VERSION=
NOTION_WORKSPACE_ID=
NOTION_SANDBOX_DATA_SOURCE_ID=

# -----------------------------------------------------------------------------
# Stripe
# Auth: test-mode secret key
# Sandbox granularity: one throwaway customer
# Targets: targets/stripe/pack.yaml
# -----------------------------------------------------------------------------
STRIPE_API_KEY=
STRIPE_MCP_API_KEY=
STRIPE_SANDBOX_CUSTOMER_ID=
STRIPE_SANDBOX_ACCOUNT_ID=
