# ax-eval — env stub. Copy to .env, fill in, never commit the real one.
#
# Each pack declares the env it needs (auth + sandbox_scope + per-surface auth).
# Print the exact stub for any pack with:
#
#     ax-eval init --pack <pack.yaml>                    # api + sandbox stub
#     ax-eval init --pack <pack.yaml> --surface all      # + every surface's auth
#     ax-eval check-env --pack <pack.yaml> --surface all # verifies what's set
#
# Surfaces authenticate independently. A missing SDK/CLI/MCP credential blocks
# only that surface; other runnable surfaces still execute and the report marks
# the missing one as "blocked", not 0%.
#
# Keyless paths need NONE of these:
#   ax-eval run --offline   ·   ax-eval audit --site <url>   ·   npm test

# --- Notion (REST, four surfaces) --- targets/notion/pack.yaml
# NOTION_TOKEN=                    # api + sdk (sdk inherits this token)
# NOTION_VERIFY_TOKEN=             # optional; falls back to NOTION_TOKEN
# NOTION_SANDBOX_PARENT_PAGE_ID=
# NOTION_SANDBOX_DATA_SOURCE_ID=   # optional
# NOTION_API_TOKEN=                # optional CLI alias; NOTION_TOKEN also works
# NOTION_WORKSPACE_ID=             # optional CLI helper
# NOTION_API_VERSION=              # optional; defaults to the pack header

# --- Stripe (REST, four surfaces, test mode) --- targets/stripe/pack.yaml
# STRIPE_SECRET_KEY=               # test-mode API key
# STRIPE_VERIFY_SECRET_KEY=        # optional; falls back to STRIPE_SECRET_KEY
# STRIPE_MCP_SECRET_KEY=           # optional MCP token; often same test key
