# AX eval — environment variables (example)
#
# Copy to .env and fill in. Never commit the real .env.
# None of these are required for the keyless path (mock/hermes-stub harnesses,
# mock oracles). They are only needed for live runs against real targets (M1+).

# --- Target: Asana ---
# Personal Access Token for a THROWAWAY Asana sandbox project (the agent's BYOK).
ASANA_PAT=
# Oracle verification key — OPTIONAL. The oracle reads state back with this and
# falls back to ASANA_PAT if unset. Asana PATs can't be scoped, so a second
# same-account token buys no real isolation; leave blank for v0 (plan.md §2/§3).
ASANA_VERIFY_PAT=
# The sandbox project the agent mutates and reset cleans (plan.md §3).
ASANA_SANDBOX_PROJECT_GID=

# --- Harness: Claude Code (Anthropic) ---
ANTHROPIC_API_KEY=

# --- Harness: Codex (OpenAI) ---
OPENAI_API_KEY=

# --- Harness: Hermes ---
# Provider/auth still TBD. The bundled Hermes adapter is a keyless stub until
# this is wired up; setting a key is not required to run it in stub mode.
HERMES_API_KEY=
