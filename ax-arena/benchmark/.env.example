# ax-arena benchmark — environment template
#
# Copy only the values needed for one reviewed DAEB cohort into the
# repository-root `.env`. Harness credentials stay in the root ax-eval
# template. Runtime image, harness, Bubblewrap, and Turso executable identity
# come only from `trusted-runtime/runtime-lock.json`; do not override them here.

# Neon
NEON_API_KEY=
NEON_PROJECT_ID=
NEON_BRANCH_ID=
NEON_DATABASE_URL=

# CockroachDB
COCKROACH_API_KEY=
COCKROACH_CONNECTION_STRING=

# Turso
TURSO_DATABASE_AUTH_TOKEN=
TURSO_ORG_API_TOKEN=
TURSO_API_TOKEN=
TURSO_SANDBOX_DATABASE=
TURSO_ORG=

# Supabase
SUPABASE_API_KEY=
SUPABASE_DB_URL=
SUPABASE_PROJECT_REF=

# Insforge
INSFORGE_PROJECT_URL=
INSFORGE_API_KEY=
INSFORGE_CONNECTION_STRING=

# Nile
NILE_API_KEY=
NILE_WORKSPACE=
NILE_DB=
NILE_DATABASE_URL=
