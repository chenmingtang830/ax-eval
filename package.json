{
  "name": "ax-eval",
  "version": "0.2.0",
  "description": "ax-eval — measure whether software products can be operated by AI agents, across API, CLI, SDK, and MCP surfaces.",
  "keywords": [
    "agent",
    "agent-experience",
    "eval",
    "evaluation",
    "saas",
    "aeo",
    "agent-readiness",
    "mcp",
    "openapi",
    "graphql",
    "llm"
  ],
  "type": "module",
  "license": "MIT",
  "author": "Richard Tang (https://github.com/chenmingtang830)",
  "homepage": "https://github.com/chenmingtang830/ax-eval#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chenmingtang830/ax-eval.git"
  },
  "bugs": {
    "url": "https://github.com/chenmingtang830/ax-eval/issues"
  },
  "bin": {
    "ax-eval": "./dist/cli.js"
  },
  "files": [
    ".env.example",
    "assets",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "dist",
    "SKILL.md",
    "targets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "ax-eval": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm --clean",
    "prepublishOnly": "npm run build",
    "test": "vitest run tests",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
