{
  "name": "ax-eval",
  "version": "0.3.0",
  "description": "ax-eval — Test whether AI agents can use your product across API, CLI, SDK, and MCP surfaces.",
  "keywords": [
    "agent",
    "agent-experience",
    "eval",
    "evaluation",
    "saas",
    "mcp",
    "openapi",
    "graphql",
    "llm"
  ],
  "type": "module",
  "license": "MIT",
  "author": "Richard Tang (https://github.com/chenmingtang830)",
  "homepage": "https://github.com/chenmingtang830/ax-eval#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chenmingtang830/ax-eval.git"
  },
  "bugs": {
    "url": "https://github.com/chenmingtang830/ax-eval/issues"
  },
  "workspaces": [
    "ax-arena/benchmark"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/evaluation-cell.v1.json": "./schemas/evaluation-cell.v1.json",
    "./schemas/normalized-cell-record.v1.json": "./schemas/normalized-cell-record.v1.json",
    "./schemas/normalized-result.v1.json": "./schemas/normalized-result.v1.json",
    "./package.json": "./package.json"
  },
  "bin": {
    "ax-eval": "./dist/cli.js"
  },
  "files": [
    ".env.example",
    "assets",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "dist",
    "examples",
    "schemas",
    "SKILL.md",
    "targets/README.md",
    "targets/examples/*/pack.yaml",
    "targets/examples/*/pack.approval.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "ax-eval": "tsx src/cli.ts",
    "ax-arena": "npm run ax-arena --workspace @ax-arena/benchmark --",
    "build:core": "tsup src/cli.ts src/index.ts --format esm --dts --clean",
    "build:arena": "npm run build --workspace @ax-arena/benchmark",
    "build": "npm run build:core && npm run build:arena",
    "prepublishOnly": "npm run build:arena && node .github/verify-arena-release-gate.mjs && npm run build:core",
    "pack:check:core": "node .github/verify-package-contents.mjs",
    "pack:check:arena": "npm run pack:check --workspace @ax-arena/benchmark",
    "pack:check": "npm run pack:check:core && npm run pack:check:arena",
    "check:boundaries": "node .github/verify-import-boundaries.mjs",
    "test:core": "vitest run tests",
    "test:arena": "npm test --workspace @ax-arena/benchmark",
    "test": "npm run test:core && npm run test:arena",
    "typecheck:core": "tsc --noEmit",
    "typecheck:arena": "npm run typecheck --workspace @ax-arena/benchmark",
    "typecheck": "npm run typecheck:core && npm run typecheck:arena"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@linear/sdk": "^86.0.0",
    "@mondaydotcomorg/monday-api-mcp": "^3.2.0",
    "@notionhq/client": "^5.22.0",
    "asana": "^3.1.12",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-prometheus": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "esbuild": "^0.28.1",
    "uuid": "^11.1.1"
  }
}
