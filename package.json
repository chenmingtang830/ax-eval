{
  "name": "ax-eval",
  "version": "0.3.0",
  "description": "ax-eval — Test whether AI agents can use your product across API, CLI, SDK, and MCP surfaces.",
  "keywords": [
    "agent",
    "agent-experience",
    "eval",
    "evaluation",
    "saas",
    "mcp",
    "openapi",
    "graphql",
    "llm"
  ],
  "type": "module",
  "license": "MIT",
  "author": "Richard Tang (https://github.com/chenmingtang830)",
  "homepage": "https://github.com/chenmingtang830/ax-eval#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chenmingtang830/ax-eval.git"
  },
  "bugs": {
    "url": "https://github.com/chenmingtang830/ax-eval/issues"
  },
  "bin": {
    "ax-eval": "./dist/cli.js"
  },
  "files": [
    ".env.example",
    "assets",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "dist",
    "examples",
    "SKILL.md",
    "targets/README.md",
    "targets/examples/*/pack.yaml",
    "targets/examples/*/pack.approval.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "ax-eval": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm --clean",
    "check:approvals": "vitest run tests/example-approvals.test.ts",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run build",
    "test": "vitest run tests",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@linear/sdk": "^86.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mondaydotcomorg/monday-api-mcp": "^3.2.0",
    "@notionhq/client": "^5.22.0",
    "asana": "^3.1.12",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-prometheus": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "esbuild": "^0.28.1",
    "uuid": "^11.1.1"
  }
}
