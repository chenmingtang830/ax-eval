# Secrets — never commit real keys
.env
.env.*
!.env.example

# Node / TypeScript
node_modules/
dist/
build/
*.tsbuildinfo
.npm/
.npm-cache/
.claude/
.codex/
.understand-anything/

# Run artifacts (created on demand by the CLI) — local only, never published
results/
reports/
transcripts/
runs/
*.log

# Internal docs — kept on disk for the maintainer; not part of the public repo.
# Public-facing content lives in README.md. Images the README embeds live in assets/.
docs/

# Maintainer scratch — live repro scripts (Asana/Monday); not part of the public
# skill. Kept on disk locally; the product surface is the `ax-eval` CLI.
scripts/
run-*.cjs

# Locally generated target packs can contain sandbox-specific review state.
targets/*/generated*.pack.yaml
targets/*/generated*.pack.approval.json
!targets/examples/
!targets/examples/**/
!targets/examples/*/generated*.pack.yaml
!targets/examples/*/generated*.pack.approval.json

# OS / editor
.DS_Store
